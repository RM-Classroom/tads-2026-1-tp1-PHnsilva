@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content="Painel administrativo da locadora de veículos" />
    <title>Rota Certa | Gestão de locadora</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500;600;700&family=Manrope:wght@600;700;800&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="~/css/app.css" asp-append-version="true" />
</head>
<body>
    <div class="app-shell">
        <aside class="sidebar" id="sidebar" aria-label="Navegação principal">
            <div class="brand">
                <span class="brand-mark" aria-hidden="true">
                    <svg viewBox="0 0 24 24"><path d="M5 17h14M7 17l1-5h8l1 5M9 12l1.4-3h3.2L15 12M7 19v1m10-1v1" /></svg>
                </span>
                <span><strong>Rota Certa</strong><small>Gestão de locadora</small></span>
            </div>

            <nav class="main-nav" id="main-nav">
                <p class="nav-label">Visão geral</p>
                <a href="#dashboard" data-page="dashboard" class="nav-link active">
                    <span class="nav-icon">⌂</span> Dashboard
                </a>
                <p class="nav-label">Operação</p>
                <a href="#alugueis" data-page="alugueis" class="nav-link">
                    <span class="nav-icon">↗</span> Aluguéis
                </a>
                <a href="#veiculos" data-page="veiculos" class="nav-link">
                    <span class="nav-icon">◇</span> Veículos
                </a>
                <a href="#clientes" data-page="clientes" class="nav-link">
                    <span class="nav-icon">○</span> Clientes
                </a>
                <p class="nav-label">Cadastros</p>
                <a href="#fabricantes" data-page="fabricantes" class="nav-link">
                    <span class="nav-icon">▦</span> Fabricantes
                </a>
                <a href="#categorias" data-page="categorias" class="nav-link">
                    <span class="nav-icon">▤</span> Categorias
                </a>
            </nav>

            <div class="sidebar-footer">
                <a href="/swagger" target="_blank" rel="noopener" class="api-link">
                    <span>API Swagger</span><span aria-hidden="true">↗</span>
                </a>
                <div class="operator">
                    <span class="avatar">PH</span>
                    <span><strong>Pedro Henrique</strong><small>Administrador</small></span>
                </div>
            </div>
        </aside>

        <div class="app-main">
            <header class="topbar">
                <button class="icon-button menu-toggle" id="menu-toggle" aria-label="Abrir menu" aria-expanded="false">☰</button>
                <div class="page-heading">
                    <span class="eyebrow" id="page-eyebrow">Visão geral</span>
                    <h1 id="page-title">Dashboard</h1>
                </div>
                <div class="topbar-actions">
                    <span class="connection-status loading" id="connection-status"><i></i> Conectando</span>
                    <button class="icon-button" id="refresh-button" aria-label="Atualizar dados" title="Atualizar dados">↻</button>
                    <button class="primary-button" id="new-record-button" type="button">+ Novo aluguel</button>
                </div>
            </header>

            <main class="content" id="app-content" tabindex="-1">
                <section class="page active" id="page-dashboard" data-page="dashboard" aria-labelledby="dashboard-title">
                    <div class="welcome-row">
                        <div>
                            <p class="eyebrow">Domingo, 21 de junho</p>
                            <h2 id="dashboard-title">A operação em um só lugar.</h2>
                            <p>Acompanhe a frota, os contratos e o desempenho da locadora.</p>
                        </div>
                        <button class="secondary-button" type="button" data-action="navigate" data-target="alugueis">Ver todos os aluguéis <span>→</span></button>
                    </div>

                    <div class="metric-grid" id="metric-grid" aria-label="Indicadores da locadora">
                        <article class="metric-card accent"><span class="metric-icon">↗</span><p>Aluguéis ativos</p><strong id="metric-active">—</strong><small id="metric-overdue">Carregando dados</small></article>
                        <article class="metric-card"><span class="metric-icon">◇</span><p>Veículos cadastrados</p><strong id="metric-vehicles">—</strong><small id="metric-available">Carregando dados</small></article>
                        <article class="metric-card"><span class="metric-icon">○</span><p>Clientes</p><strong id="metric-clients">—</strong><small>Base total cadastrada</small></article>
                        <article class="metric-card"><span class="metric-icon">$</span><p>Receita contratada</p><strong id="metric-revenue">—</strong><small>Soma dos contratos</small></article>
                    </div>

                    <div class="dashboard-grid">
                        <section class="panel fleet-panel">
                            <div class="panel-heading"><div><span class="eyebrow">Distribuição</span><h3>Frota por fabricante</h3></div><button class="text-button" data-action="navigate" data-target="fabricantes">Gerenciar</button></div>
                            <div class="bar-chart" id="manufacturer-chart"></div>
                        </section>
                        <section class="panel availability-panel">
                            <div class="panel-heading"><div><span class="eyebrow">Disponibilidade</span><h3>Veículos sem aluguel</h3></div><span class="panel-count" id="available-count">0</span></div>
                            <div class="compact-list" id="available-vehicles"></div>
                        </section>
                    </div>

                    <section class="panel recent-panel">
                        <div class="panel-heading"><div><span class="eyebrow">Movimentação recente</span><h3>Últimos aluguéis</h3></div><button class="text-button" data-action="navigate" data-target="alugueis">Ver histórico →</button></div>
                        <div class="table-wrap"><table><thead><tr><th>Cliente</th><th>Veículo</th><th>Período</th><th>Status</th><th class="align-right">Valor</th></tr></thead><tbody id="recent-rentals"></tbody></table></div>
                    </section>
                </section>

                <section class="page" id="page-entity" data-page="entity" aria-live="polite">
                    <div class="entity-intro">
                        <div><span class="eyebrow" id="entity-eyebrow">Cadastros</span><h2 id="entity-title">Registros</h2><p id="entity-description"></p></div>
                        <button class="primary-button" id="entity-new-button" type="button">+ Novo registro</button>
                    </div>

                    <section class="panel filter-panel" aria-label="Filtros">
                        <div class="filter-heading"><div><h3>Filtros</h3><p>Refine os registros pelos campos abaixo.</p></div><button type="button" class="text-button" id="clear-filters">Limpar filtros</button></div>
                        <form class="filter-grid" id="filter-form"></form>
                    </section>

                    <section class="panel records-panel">
                        <div class="panel-heading records-heading">
                            <div><span class="eyebrow">Resultados</span><h3 id="records-title">Todos os registros</h3></div>
                            <span class="result-count" id="result-count">0 registros</span>
                        </div>
                        <div class="table-wrap"><table id="entity-table"><thead id="entity-table-head"></thead><tbody id="entity-table-body"></tbody></table></div>
                        <div class="empty-state" id="empty-state" hidden><span>⌕</span><h3>Nenhum registro encontrado</h3><p>Revise os filtros ou crie um novo cadastro.</p></div>
                    </section>
                </section>
            </main>
        </div>
    </div>

    <div class="sidebar-backdrop" id="sidebar-backdrop"></div>

    <dialog class="modal" id="record-modal" aria-labelledby="modal-title">
        <form method="dialog" class="modal-card" id="record-form">
            <div class="modal-header">
                <div><span class="eyebrow" id="modal-eyebrow">Cadastro</span><h2 id="modal-title">Novo registro</h2><p id="modal-description"></p></div>
                <button class="icon-button modal-close" type="button" data-close-modal aria-label="Fechar">×</button>
            </div>
            <div class="form-grid" id="record-fields"></div>
            <div class="form-error" id="form-error" role="alert" hidden></div>
            <div class="modal-actions"><button class="secondary-button" type="button" data-close-modal>Cancelar</button><button class="primary-button" type="submit" id="save-button">Salvar cadastro</button></div>
        </form>
    </dialog>

    <dialog class="modal confirm-modal" id="confirm-modal" aria-labelledby="confirm-title">
        <div class="modal-card">
            <div class="danger-icon">!</div><h2 id="confirm-title">Excluir registro?</h2><p id="confirm-message">Esta ação não poderá ser desfeita.</p>
            <div class="modal-actions"><button class="secondary-button" type="button" data-close-confirm>Cancelar</button><button class="danger-button" type="button" id="confirm-delete">Excluir definitivamente</button></div>
        </div>
    </dialog>

    <div class="toast-region" id="toast-region" aria-live="polite" aria-atomic="true"></div>
    <script src="~/js/app.js" asp-append-version="true"></script>
</body>
</html>
